From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Sun, 19 Jul 2026 00:00:00 +0000
Subject: [PATCH] p2: co-locate Unicode static interning

The first interpreter initializes the generated static-Unicode table before
core types.  Keep that wrapper, its generated body, and both hash-table
callbacks in the type-initialization overlay so a collision cannot replace
the overlay in the middle of every intern operation.  Fixed-text P2-only
markers make each pre-type phase independently observable on hardware.

The placement macro is empty and the diagnostics are compiled out on every
other target.
---
diff --git a/Include/internal/pycore_unicodeobject.h b/Include/internal/pycore_unicodeobject.h
--- a/Include/internal/pycore_unicodeobject.h
+++ b/Include/internal/pycore_unicodeobject.h
@@ -270,7 +270,8 @@ PyAPI_FUNC(Py_ssize_t) _PyUnicode_ScanIdentifier(PyObject *);
 /* --- Runtime lifecycle -------------------------------------------------- */
 
 extern void _PyUnicode_InitState(PyInterpreterState *);
-extern PyStatus _PyUnicode_InitGlobalObjects(PyInterpreterState *);
+extern PyStatus _PyUnicode_InitGlobalObjects(PyInterpreterState *)
+    _Py_P2_INIT_OVERLAY;
 extern PyStatus _PyUnicode_InitTypes(PyInterpreterState *);
 extern void _PyUnicode_Fini(PyInterpreterState *);
 extern void _PyUnicode_FiniTypes(PyInterpreterState *);
diff --git a/Include/internal/pycore_unicodeobject_generated.h b/Include/internal/pycore_unicodeobject_generated.h
--- a/Include/internal/pycore_unicodeobject_generated.h
+++ b/Include/internal/pycore_unicodeobject_generated.h
@@ -9,7 +9,7 @@ extern "C" {
 #endif
 
 /* The following is auto-generated by Tools/build/generate_global_objects.py. */
-static inline void
+_Py_P2_INIT_OVERLAY static inline void
 _PyUnicode_InitStaticStrings(PyInterpreterState *interp) {
     PyObject *string;
     string = &_Py_ID(CANCELLED);
diff --git a/Objects/unicodeobject.c b/Objects/unicodeobject.c
--- a/Objects/unicodeobject.c
+++ b/Objects/unicodeobject.c
@@ -256,15 +256,15 @@ _PyUnicode_InternedSize_Immortal(void)
 }
 
 _Py_P2_INIT_OVERLAY static Py_hash_t unicode_hash(PyObject *);
-static int unicode_compare_eq(PyObject *, PyObject *);
+_Py_P2_INIT_OVERLAY static int unicode_compare_eq(PyObject *, PyObject *);
 
-static Py_uhash_t
+_Py_P2_INIT_OVERLAY static Py_uhash_t
 hashtable_unicode_hash(const void *key)
 {
     return unicode_hash((PyObject *)key);
 }
 
-static int
+_Py_P2_INIT_OVERLAY static int
 hashtable_unicode_compare(const void *key1, const void *key2)
 {
     PyObject *obj1 = (PyObject *)key1;
@@ -277,7 +277,7 @@ hashtable_unicode_compare(const void *key1, const void *key2)
     }
 }
 
-static int
+_Py_P2_INIT_OVERLAY static int
 init_interned_dict(PyInterpreterState *interp)
 {
     assert(get_interned_dict(interp) == NULL);
@@ -300,7 +300,7 @@ clear_interned_dict(PyInterpreterState *interp)
     }
 }
 
-static PyStatus
+_Py_P2_INIT_OVERLAY static PyStatus
 init_global_interned_strings(PyInterpreterState *interp)
 {
     assert(INTERNED_STRINGS == NULL);
@@ -327,13 +327,23 @@ init_global_interned_strings(PyInterpreterState *interp)
         * Deepfreeze uses the interned identifiers if present to save space
         * else generates them and they are interned to speed up dict lookups.
     */
+#if defined(__NuttX__) && defined(__propeller2__)
+    printf("P2PY:INIT:UNICODE_STATIC:BEGIN\n");
+#endif
     _PyUnicode_InitStaticStrings(interp);
+#if defined(__NuttX__) && defined(__propeller2__)
+    printf("P2PY:INIT:UNICODE_STATIC:PASS\n");
+    printf("P2PY:INIT:LATIN1:BEGIN\n");
+#endif
 
     for (int i = 0; i < 256; i++) {
         PyObject *s = LATIN1(i);
         _PyUnicode_InternStatic(interp, &s);
         assert(s == LATIN1(i));
     }
+#if defined(__NuttX__) && defined(__propeller2__)
+    printf("P2PY:INIT:LATIN1:PASS\n");
+#endif
 #ifdef Py_DEBUG
     assert(_PyUnicode_CheckConsistency(&_Py_STR(empty), 1));
 
@@ -10748,7 +10758,7 @@ unicode_compare(PyObject *str1, PyObject *str2)
 #undef COMPARE
 }
 
-static int
+_Py_P2_INIT_OVERLAY static int
 unicode_compare_eq(PyObject *str1, PyObject *str2)
 {
     int kind;
@@ -15011,7 +15021,7 @@ _PyUnicode_InitState(PyInterpreterState *interp)
 }
 
 
-PyStatus
+_Py_P2_INIT_OVERLAY PyStatus
 _PyUnicode_InitGlobalObjects(PyInterpreterState *interp)
 {
     if (_Py_IsMainInterpreter(interp)) {
diff --git a/Tools/build/generate_global_objects.py b/Tools/build/generate_global_objects.py
--- a/Tools/build/generate_global_objects.py
+++ b/Tools/build/generate_global_objects.py
@@ -363,7 +363,7 @@ def generate_static_strings_initializer(identifiers, strings):
         printer = Printer(outfile)
         printer.write(before)
         printer.write(START)
-        printer.write("static inline void")
+        printer.write("_Py_P2_INIT_OVERLAY static inline void")
         with printer.block("_PyUnicode_InitStaticStrings(PyInterpreterState *interp)"):
             printer.write(f'PyObject *string;')
             for i in sorted(identifiers):
diff --git a/Python/pylifecycle.c b/Python/pylifecycle.c
--- a/Python/pylifecycle.c
+++ b/Python/pylifecycle.c
@@ -883,27 +883,45 @@ pycore_interp_init(PyThreadState *tstate)
     // Create singletons before the first PyType_Ready() call, since
     // PyType_Ready() uses singletons like the Unicode empty string (tp_doc)
     // and the empty tuple singletons (tp_bases).
+#if defined(__NuttX__) && defined(__propeller2__)
+    printf("P2PY:INIT:GLOBAL_OBJECTS:BEGIN\n");
+#endif
     status = pycore_init_global_objects(interp);
     if (_PyStatus_EXCEPTION(status)) {
         return status;
     }
+#if defined(__NuttX__) && defined(__propeller2__)
+    printf("P2PY:INIT:GLOBAL_OBJECTS:PASS\n");
+    printf("P2PY:INIT:CODE:BEGIN\n");
+#endif
 
     status = _PyCode_Init(interp);
     if (_PyStatus_EXCEPTION(status)) {
         return status;
     }
+#if defined(__NuttX__) && defined(__propeller2__)
+    printf("P2PY:INIT:CODE:PASS\n");
+    printf("P2PY:INIT:DTOA:BEGIN\n");
+#endif
 
     status = _PyDtoa_Init(interp);
     if (_PyStatus_EXCEPTION(status)) {
         return status;
     }
+#if defined(__NuttX__) && defined(__propeller2__)
+    printf("P2PY:INIT:DTOA:PASS\n");
+    printf("P2PY:INIT:GC:BEGIN\n");
+#endif
 
     // The GC must be initialized before the first GC collection.
     status = _PyGC_Init(interp);
     if (_PyStatus_EXCEPTION(status)) {
         return status;
     }
+#if defined(__NuttX__) && defined(__propeller2__)
+    printf("P2PY:INIT:GC:PASS\n");
+#endif
 
     status = pycore_init_types(interp);
     if (_PyStatus_EXCEPTION(status)) {
         goto done;
-- 
