 PyAPI_FUNC(PyObject *) PyDict_Values(PyObject *mp) _Py_P2_INIT_OVERLAY;
-PyAPI_FUNC(PyObject *) PyDict_Items(PyObject *mp) _Py_P2_INIT_OVERLAY;
+PyAPI_FUNC(PyObject *) PyDict_Items(PyObject *mp);
 PyAPI_FUNC(Py_ssize_t) PyDict_Size(PyObject *mp) _Py_P2_INIT_OVERLAY;
 PyAPI_FUNC(PyObject *) PyDict_Copy(PyObject *mp);
