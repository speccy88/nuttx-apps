 #  define _Py_P2_GC_OVERLAY __attribute__((p2_hub_overlay(8)))
 #  define _Py_P2_CODEINIT_OVERLAY __attribute__((p2_hub_overlay(9)))
+#  define _Py_P2_COMPARE_OVERLAY __attribute__((p2_hub_overlay(10)))
 #  define _Py_P2_UTF8_OVERLAY __attribute__((p2_hub_overlay(6)))
 #else
 #  define _Py_P2_HUB_RESIDENT
 #  define _Py_P2_INIT_OVERLAY
 #  define _Py_P2_GC_OVERLAY
 #  define _Py_P2_CODEINIT_OVERLAY
+#  define _Py_P2_COMPARE_OVERLAY
 #  define _Py_P2_UTF8_OVERLAY
 #endif
 
