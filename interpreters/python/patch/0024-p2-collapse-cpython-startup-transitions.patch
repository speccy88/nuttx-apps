     _Py_hashtable_t *ht,
     const void *key,
-    void *value);
+    void *value) _Py_P2_HUB_RESIDENT;
 
 
 /* Get an entry.
@@ -131,7 +131,8 @@ _Py_hashtable_get_entry(_Py_hashtable_t *ht, const void *key)
 
    Use _Py_hashtable_get_entry() to distinguish entry value equal to NULL
    and entry not found. */
-PyAPI_FUNC(void*) _Py_hashtable_get(_Py_hashtable_t *ht, const void *key);
+PyAPI_FUNC(void*) _Py_hashtable_get(_Py_hashtable_t *ht, const void *key)
