+_Py_P2_COMPARE_OVERLAY static int unicode_compare_eq(PyObject *, PyObject *);
 
 _Py_P2_INIT_OVERLAY static Py_uhash_t
 hashtable_unicode_hash(const void *key)
@@ -10758,7 +10758,7 @@ unicode_compare(PyObject *str1, PyObject *str2)
 #undef COMPARE
 }
 
-_Py_P2_INIT_OVERLAY static int
+_Py_P2_COMPARE_OVERLAY static int
