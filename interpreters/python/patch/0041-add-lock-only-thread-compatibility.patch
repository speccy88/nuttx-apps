From 8a5e04e885749822382bb51ade8e69e330409313 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Sun, 19 Jul 2026 22:30:00 -0400
Subject: [PATCH] p2: add lock-only _thread compatibility

The P2 Python profile permits one Python task because its hub-overlay slot has
one owner.  Several otherwise useful pure-Python stdlib modules import only
the lock subset of _thread, however, and do not need task creation.

Provide that narrow subset as a dependency-free Python module in the external
stdlib archive.  Its locks track real state and fail instead of deadlocking
when the sole task tries to block on its own non-recursive lock.  Every task
creation spelling fails before it can execute the supplied callback.

Reject threading explicitly and early so importing the compatibility module
can never be mistaken for support for Thread.start().  Also retain _pyio in
the stdlib archive because it is a direct consumer of allocate_lock().  The
compatibility layer is bytecode-only and adds no resident code or overlay
stubs.
---
 Lib/_thread.py            | 128 +++++++++++++++++++++++++++++++++++++++
 Lib/threading.py          |   7 ++
 Tools/wasm/wasm_assets.py |   1 -
 3 files changed, 135 insertions(+), 1 deletion(-)
 create mode 100644 Lib/_thread.py

diff --git a/Lib/_thread.py b/Lib/_thread.py
new file mode 100644
--- /dev/null
+++ b/Lib/_thread.py
@@ -0,0 +1,128 @@
+"""Lock-only compatibility for the single-task NuttX P2 Python profile."""
+
+_NUTTX_LOCK_ONLY = True
+_SINGLE_TASK_IDENT = 1
+_THREAD_CREATION_ERROR = (
+    "thread creation is unavailable: this NuttX P2 profile supports one "
+    "Python task and only lock-only _thread compatibility"
+)
+
+error = RuntimeError
+
+
+def _validate_acquire(blocking, timeout):
+    blocking = bool(blocking)
+    if not blocking and timeout != -1:
+        raise ValueError("can't specify a timeout for a non-blocking call")
+    if timeout < 0 and timeout != -1:
+        raise ValueError("timeout value must be positive")
+    return blocking
+
+
+class LockType:
+    """A stateful lock for code executing in the sole Python task."""
+
+    __slots__ = ("_locked",)
+
+    def __init__(self):
+        self._locked = False
+
+    def acquire(self, blocking=True, timeout=-1):
+        blocking = _validate_acquire(blocking, timeout)
+        if not self._locked:
+            self._locked = True
+            return True
+        if not blocking or timeout == 0:
+            return False
+        raise error("lock-only _thread lock would block the only Python task")
+
+    acquire_lock = acquire
+
+    def release(self):
+        if not self._locked:
+            raise error("release unlocked lock")
+        self._locked = False
+
+    release_lock = release
+
+    def locked(self):
+        return self._locked
+
+    locked_lock = locked
+
+    def _at_fork_reinit(self):
+        self._locked = False
+
+    __enter__ = acquire
+
+    def __exit__(self, *ignored):
+        self.release()
+
+
+def allocate_lock():
+    return LockType()
+
+
+allocate = allocate_lock
+
+
+class RLock:
+    """A recursive lock owned by the sole Python task."""
+
+    __slots__ = ("_count",)
+
+    def __init__(self):
+        self._count = 0
+
+    def acquire(self, blocking=True, timeout=-1):
+        _validate_acquire(blocking, timeout)
+        self._count += 1
+        return True
+
+    acquire_lock = acquire
+    __enter__ = acquire
+
+    def release(self):
+        if self._count == 0:
+            raise error("cannot release un-acquired lock")
+        self._count -= 1
+
+    release_lock = release
+
+    def locked(self):
+        return self._count != 0
+
+    locked_lock = locked
+
+    def _is_owned(self):
+        return self._count != 0
+
+    def _recursion_count(self):
+        return self._count
+
+    def _at_fork_reinit(self):
+        self._count = 0
+
+    def __exit__(self, *ignored):
+        self.release()
+
+
+def get_ident():
+    """Return the stable, nonzero identity of the sole Python task."""
+
+    return _SINGLE_TASK_IDENT
+
+
+def start_new_thread(function, args, kwargs=None):
+    """Reject thread creation without invoking *function*."""
+
+    raise NotImplementedError(_THREAD_CREATION_ERROR)
+
+
+start_new = start_new_thread
+
+
+def start_joinable_thread(function, handle=None, daemon=True):
+    """Reject joinable thread creation without invoking *function*."""
+
+    raise NotImplementedError(_THREAD_CREATION_ERROR)
diff --git a/Lib/threading.py b/Lib/threading.py
--- a/Lib/threading.py
+++ b/Lib/threading.py
@@ -3,6 +3,13 @@
 import os as _os
 import sys as _sys
 import _thread
+
+if getattr(_thread, "_NUTTX_LOCK_ONLY", False):
+    raise ImportError(
+        "threading is unavailable: this NuttX P2 profile supports one "
+        "Python task and only lock-only _thread compatibility"
+    )
+
 import warnings
 
 from time import monotonic as _time
diff --git a/Tools/wasm/wasm_assets.py b/Tools/wasm/wasm_assets.py
--- a/Tools/wasm/wasm_assets.py
+++ b/Tools/wasm/wasm_assets.py
@@ -50,7 +50,6 @@ OMIT_FILES = (
     # Pure Python implementations of C extensions.
     # NOTE: keep "_pydecimal.py" so decimal.py can fall back to it when the
     # _decimal C extension is not built (NuttX targets do not link libmpdec).
-    "_pyio.py",
     # concurrent threading
     "concurrent/futures/thread.py",
     # Misc unused or large files
-- 
2.50.1
