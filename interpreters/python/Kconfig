#
# For a description of the syntax of this configuration file,
# see the file kconfig-language.txt in the NuttX tools repository.
#

config INTERPRETERS_CPYTHON
	tristate "CPython"
	depends on LIB_ZLIB
	depends on !DISABLE_PTHREAD
	depends on !LIBC_DLFCN || LIB_LIBFFI
	depends on EXPERIMENTAL
	default n
	---help---
		Enable the CPython port to NuttX. This is a port of the Python
		interpreter to NuttX. Initially, it is tweaked to work with the
		RISC-V QEMU virtual board (`rv-virt`).

if INTERPRETERS_CPYTHON

config INTERPRETERS_CPYTHON_VERSION
	string "Python Version"
	default "3.13.0"

config INTERPRETERS_CPYTHON_STACKSIZE
	int "CPython stack size"
	default 307200
	---help---
		This is the stack size allocated for the CPython worker thread.  The
		command launcher has a separate, smaller stack so it can reject a
		concurrent interpreter before allocating this stack.

config INTERPRETERS_CPYTHON_LAUNCHER_STACKSIZE
	int "CPython command launcher stack size"
	default 2048
	range 1024 16384
	---help---
		This is the stack size allocated for the CPython command entry point.
		It only guards the process-global runtime, creates one worker, and
		waits for it.  The interpreter itself uses
		INTERPRETERS_CPYTHON_STACKSIZE.

config INTERPRETERS_CPYTHON_P2_OVERLAY_TELEMETRY
	bool "Report P2 CPython overlay progress"
	default n
	depends on ARCH_P2 && P2_HUB_OVERLAYS
	---help---
		Keep the small command task awake while its CPython worker runs and
		periodically report coherent resident overlay counters.  This does not
		enter overlay code and is safe while the worker owns the single Hub
		execution slot.  It is intended for target qualification and diagnosing
		an apparent interpreter stall.

config INTERPRETERS_CPYTHON_P2_OVERLAY_TELEMETRY_INTERVAL_MS
	int "P2 CPython overlay report interval (milliseconds)"
	default 60000
	range 1000 60000
	depends on INTERPRETERS_CPYTHON_P2_OVERLAY_TELEMETRY
	---help---
		Elapsed time between progress records while the CPython worker is live.
		The default emits the bounded eight-record P2PY:HOT snapshot about once a
		minute, plus one final snapshot when the worker exits.

config INTERPRETERS_CPYTHON_P2_DEFAULT_NO_SITE
	bool "Skip automatic CPython site initialization on P2"
	default n
	depends on ARCH_P2
	---help---
		Start CPython with PyConfig.site_import disabled on Propeller 2.  This
		sets sys.flags.no_site without rewriting the command-line arguments.
		The site module remains available for an explicit import followed by
		site.main().  This can reduce startup overlay traffic on small-Hub P2
		targets while preserving an opt-in path for normal site processing.

config INTERPRETERS_CPYTHON_P2_FIXED_PATH_CONFIG
	bool "Use the fixed NuttX CPython path layout on P2"
	default n
	depends on ARCH_P2
	---help---
		Populate PyConfig directly from the NuttX CPython filesystem contract
		instead of evaluating CPython's frozen getpath.py during startup.  The
		writable path comes from INTERPRETERS_CPYTHON_PYTHONPATH and the standard
		library archive must be mounted as
		/usr/local/lib/python<major><minor>.zip.  Leave this disabled for boards
		that do not provide that exact layout.

config INTERPRETERS_CPYTHON_PRIORITY
	int "CPython task priority"
	default 100
	---help---
		This is the priority of the CPython task.

config INTERPRETERS_CPYTHON_PROGNAME
	string "CPython name"
	default "python"
	---help---
		This is the name of the program that will be used from the nsh.

config INTERPRETERS_CPYTHON_ENABLE_PIP
	bool "Enable bundled pip"
	default n
	---help---
		Enable bundling pip into the CPython module image. When enabled, the
		build downloads the pip wheel and pre-installs it through a
		site-packages .pth entry that points to ensurepip's bundled wheel.
		Disable this to skip pip wheel download/integration entirely.

config INTERPRETERS_CPYTHON_INSTALL_NUTTX_PACKAGE
	bool "Install NuttX Python package"
	default y
	---help---
		Installs the nuttx-periphery Python package into the CPython module image.
		This allows importing the nuttx-periphery package into the CPython interpreter,
		which provides a Python interface to the NuttX's peripheral drivers.

config INTERPRETERS_CPYTHON_PYTHONPATH
	string "CPython Python path"
	default "/tmp"
	---help---
		This is the Python default search path for modules files. This is
		required to be a writable path.

config INTERPRETERS_CPYTHON_EXTERNAL_ROMFS
	bool "Provide the CPython ROMFS from board-managed memory"
	default n
	---help---
		Do not compile the standard-library ROMFS into the application archive.
		The board must validate and publish an immutable image through
		board_cpython_runtime_prepare() and board_cpython_romfs_image(), validate
		the writable runtime filesystem through board_cpython_tmpfs_validate(),
		then register the image through board_cpython_romdisk_register().  The
		registration hook must select buffered access when the returned pointer
		is not a true CPU-addressable XIP mapping.  This is intended for targets such as
		Propeller 2 where the module image lives in external unified memory.  The
		build still emits
		romfs_cpython_modules.img as a separately packaged artifact.

config INTERPRETERS_CPYTHON_ROMFS_SECTORSIZE
	int "CPython ROMFS block sector size"
	default 64
	range 16 4096
	---help---
		Sector size exposed by the CPython ROM disk.  External memories with a
		non-trivial transfer setup cost benefit from a larger sector, at the
		cost of one sector-sized filesystem cache allocation per open file.

endif
