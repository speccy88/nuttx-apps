 Include/cpython/dictobject.h | 11 ++++-------
 Include/dictobject.h         |  2 +-
 Include/object.h             |  6 ++++--
 Include/pyport.h             |  2 ++
 Include/unicodeobject.h      |  2 +-
 Objects/codeobject.c         |  2 +-
 Objects/dictobject.c         | 10 +++++-----
 Objects/object.c             |  4 ++--
 Objects/typeobject.c         |  2 +-
 Objects/unicodeobject.c      |  8 ++++----
 10 files changed, 25 insertions(+), 24 deletions(-)

diff --git a/Include/cpython/dictobject.h b/Include/cpython/dictobject.h
index 4e2358c..619dba6 100644
