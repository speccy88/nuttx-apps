From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Sat, 18 Jul 2026 00:00:00 +0000
Subject: [PATCH] p2: collapse measured CPython startup transitions

Keep the UTF-8 decoder family in one small explicit overlay and pin the
startup services that otherwise alternate between large automatic groups
during configuration, static-string interning, and type-cache setup.  These
placements are selected from HIL overlay telemetry; they avoid repeated PSRAM
loads without changing CPython semantics on P2 or any other architecture.
---
 15 files changed, 40 insertions(+), 22 deletions(-)

--- a/Include/internal/pycore_fileutils.h
+++ b/Include/internal/pycore_fileutils.h
@@ -213,7 +213,7 @@ extern int _Py_DecodeUTF8Ex(
     wchar_t **wstr,
     size_t *wlen,
     const char **reason,
-    _Py_error_handler errors);
+    _Py_error_handler errors) _Py_P2_UTF8_OVERLAY;
 
 extern int _Py_EncodeUTF8Ex(
     const wchar_t *text,
--- a/Include/internal/pycore_getopt.h
+++ b/Include/internal/pycore_getopt.h
@@ -9,7 +9,7 @@ extern int _PyOS_opterr;
 extern Py_ssize_t _PyOS_optind;
 extern const wchar_t *_PyOS_optarg;
 
-extern void _PyOS_ResetGetOpt(void);
+extern void _PyOS_ResetGetOpt(void) _Py_P2_HUB_RESIDENT;
 
 typedef struct {
     const wchar_t *name;
@@ -17,6 +17,7 @@ typedef struct {
     int val;
 } _PyOS_LongOption;
 
-extern int _PyOS_GetOpt(Py_ssize_t argc, wchar_t * const *argv, int *longindex);
+extern int _PyOS_GetOpt(Py_ssize_t argc, wchar_t * const *argv, int *longindex)
+    _Py_P2_HUB_RESIDENT;
 
 #endif /* !Py_INTERNAL_PYGETOPT_H */
--- a/Include/internal/pycore_hashtable.h
+++ b/Include/internal/pycore_hashtable.h
@@ -114,7 +114,7 @@ PyAPI_FUNC(size_t) _Py_hashtable_len(const _Py_hashtable_t *ht);
